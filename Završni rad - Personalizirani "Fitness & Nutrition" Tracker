void ocisti_ulazni_buffer(void)
{
    int znak;
    znak = getchar();
    while (znak != '\n')
    {
        if (znak == EOF)
        {
            break;
        }
        znak = getchar();
    }
}

int provjera_unosa_int(int minimum, int maksimum)
{
    int broj;
    int provjera;
    broj = 0;
    provjera = 0;

    while (provjera == 0)
    {
        if (scanf("%d", &broj) == 1)
        {
            if (broj >= minimum)
            {
                if (broj <= maksimum)
                {
                    provjera = 1;
                }
                else
                {
                    printf("Broj prevelik! Ponovite: ");
                }
            }
            else
            {
                printf("Broj premali! Ponovite: ");
            }
        }
        else
        {
            printf("Neispravan unos! Ponovite: ");
        }
        ocisti_ulazni_buffer();
    }
    return broj;
}

float provjera_unosa_float(float minimum, float maksimum)
{
    float broj;
    int provjera;
    broj = 0.0f;
    provjera = 0;

    while (provjera == 0)
    {
        if (scanf("%f", &broj) == 1)
        {
            if (broj >= minimum)
            {
                if (broj <= maksimum)
                {
                    provjera = 1;
                }
                else
                {
                    printf("Vrijednost prevelika! Ponovite: ");
                }
            }
            else
            {
                printf("Vrijednost premala! Ponovite: ");
            }
        }
        else
        {
            printf("Neispravan unos! Ponovite: ");
        }
        ocisti_ulazni_buffer();
    }
    return broj;
}

void provjera_unosa_string(char* spremnik, int max_velicina)
{
    char* pokazivac;
    size_t duljina;

    pokazivac = fgets(spremnik, max_velicina, stdin);

    if (pokazivac != NULL)
    {
        duljina = strlen(spremnik);
        if (duljina > 0)
        {
            if (spremnik[duljina - 1] == '\n')
            {
                spremnik[duljina - 1] = '\0';
            }
        }
    }
}

