void kreiraj_zapis_namirnice(void)
{
    FILE* pokazivac_datoteke;
    PODATAK_NAMIRNICA* novi_zapis;
    size_t rezultat_pisanja;
    char tekst_greske[256];

    pokazivac_datoteke = fopen(BAZA_NAMIRNICE, "ab");

    if (pokazivac_datoteke == NULL)
    {
        strcpy(tekst_greske, strerror(errno));
        printf("Greska pri otvaranju datoteke: %s\n", tekst_greske);
        return;
    }

    novi_zapis = (PODATAK_NAMIRNICA*)calloc(1, sizeof(PODATAK_NAMIRNICA));

    if (novi_zapis == NULL)
    {
        perror("Greska pri alokaciji memorije");
        fclose(pokazivac_datoteke);
        return;
    }

    printf("Unesite jedinstveni ID: ");
    novi_zapis->identifikator = provjera_unosa_int(1, 99999);

    printf("Unesite naziv namirnice: ");
    provjera_unosa_string(novi_zapis->naziv, MAX_STRING);

    printf("Unesite kalorijsku vrijednost: ");
    novi_zapis->energetska_vrijednost = provjera_unosa_float(0.0f, 9000.0f);

    printf("Unesite kolicinu proteina: ");
    novi_zapis->kolicina_proteina = provjera_unosa_float(0.0f, 100.0f);

    printf("Unesite kolicinu masti: ");
    novi_zapis->kolicina_masti = provjera_unosa_float(0.0f, 100.0f);

    printf("Unesite kolicinu ugljikohidrata: ");
    novi_zapis->kolicina_uh = provjera_unosa_float(0.0f, 100.0f);

    rezultat_pisanja = fwrite(novi_zapis, sizeof(PODATAK_NAMIRNICA), 1, pokazivac_datoteke);

    if (rezultat_pisanja == 1)
    {
        printf("Uspjesno zapisano u datoteku.\n");
    }
    else
    {
        printf("Doslo je do greske prilikom upisivanja.\n");
    }

    fclose(pokazivac_datoteke);

    free(novi_zapis);
    novi_zapis = NULL;
}

