void azuriraj_zapis_namirnice(void)
{
    FILE* pokazivac_datoteke;
    PODATAK_NAMIRNICA privremeni_zapis;
    int id_meta;
    int nadjeno_stanje;
    long lokacija_u_datoteci;

    pokazivac_datoteke = fopen(BAZA_NAMIRNICE, "rb+");

    if (pokazivac_datoteke == NULL)
    {
        perror("Datoteka se ne moze otvoriti za azuriranje");
        return;
    }

    printf("Unesite ID namirnice koju zelite izmijeniti: ");
    id_meta = provjera_unosa_int(1, 99999);
    nadjeno_stanje = 0;

    while (fread(&privremeni_zapis, sizeof(PODATAK_NAMIRNICA), 1, pokazivac_datoteke) == 1)
    {
        if (privremeni_zapis.identifikator == id_meta)
        {
            nadjeno_stanje = 1;

            printf("Trenutna kalorijska vrijednost za %s je %.2f\n",
                privremeni_zapis.naziv,
                privremeni_zapis.energetska_vrijednost);

            printf("Unesite novu kalorijsku vrijednost: ");
            privremeni_zapis.energetska_vrijednost = provjera_unosa_float(0.0f, 9000.0f);

            lokacija_u_datoteci = ftell(pokazivac_datoteke);
            lokacija_u_datoteci = lokacija_u_datoteci - sizeof(PODATAK_NAMIRNICA);

            fseek(pokazivac_datoteke, lokacija_u_datoteci, SEEK_SET);
            fwrite(&privremeni_zapis, sizeof(PODATAK_NAMIRNICA), 1, pokazivac_datoteke);

            printf("Podatak je uspjesno azuriran.\n");
            break;
        }
    }

    if (nadjeno_stanje == 0)
    {
        printf("Namirnica s trazenim ID brojem nije pronadjena.\n");
    }

    fclose(pokazivac_datoteke);
}

void obrisi_zapis_namirnice(void)
{
    FILE* pokazivac_izvor;
    FILE* pokazivac_odrediste;
    PODATAK_NAMIRNICA trenutna_meta;
    int id_brisanje;
    int obrisano_stanje;

    pokazivac_izvor = fopen(BAZA_NAMIRNICE, "rb");

    if (pokazivac_izvor == NULL)
    {
        perror("Greska izvorne datoteke");
        return;
    }

    pokazivac_odrediste = fopen("privremena.bin", "wb");

    if (pokazivac_odrediste == NULL)
    {
        perror("Greska kreiranja privremene datoteke");
        fclose(pokazivac_izvor);
        return;
    }

    printf("Koji ID zelite trajno obrisati: ");
    id_brisanje = provjera_unosa_int(1, 99999);
    obrisano_stanje = 0;

    while (fread(&trenutna_meta, sizeof(PODATAK_NAMIRNICA), 1, pokazivac_izvor) == 1)
    {
        if (trenutna_meta.identifikator != id_brisanje)
        {
            fwrite(&trenutna_meta, sizeof(PODATAK_NAMIRNICA), 1, pokazivac_odrediste);
        }
        else
        {
            obrisano_stanje = 1;
        }
    }

    fclose(pokazivac_izvor);
    fclose(pokazivac_odrediste);

    remove(BAZA_NAMIRNICE);
    if (rename("privremena.bin", BAZA_NAMIRNICE) != 0)
    {
        perror("Greska prilikom preimenovanja datoteke");
    }

    if (obrisano_stanje == 1)
    {
        printf("Proces brisanja je dovrsen.\n");
    }
    else
    {
        printf("Ciljani ID ne postoji.\n");
    }
}

