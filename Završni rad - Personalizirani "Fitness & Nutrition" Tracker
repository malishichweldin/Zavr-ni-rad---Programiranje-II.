int funkcija_za_qsort(const void* prvi, const void* drugi)
{
    const PODATAK_NAMIRNICA* p1;
    const PODATAK_NAMIRNICA* p2;

    p1 = (const PODATAK_NAMIRNICA*)prvi;
    p2 = (const PODATAK_NAMIRNICA*)drugi;

    if (p1->energetska_vrijednost < p2->energetska_vrijednost)
    {
        return -1;
    }
    else if (p1->energetska_vrijednost > p2->energetska_vrijednost)
    {
        return 1;
    }
    else
    {
        return 0;
    }
}

void pokreni_sortiranje_baze(void)
{
    FILE* pokazivac;
    PODATAK_NAMIRNICA* dinamicko_polje;
    long velicina_datoteke;
    int broj_elemenata;

    pokazivac = fopen(BAZA_NAMIRNICE, "rb");

    if (pokazivac == NULL)
    {
        perror("Nema datoteke za sortiranje");
        return;
    }

    fseek(pokazivac, 0, SEEK_END);
    velicina_datoteke = ftell(pokazivac);
    broj_elemenata = (int)(velicina_datoteke / sizeof(PODATAK_NAMIRNICA));
    rewind(pokazivac);

    if (broj_elemenata < 2)
    {
        printf("Nedovoljno podataka u bazi za sortiranje.\n");
        fclose(pokazivac);
        return;
    }

    dinamicko_polje = (PODATAK_NAMIRNICA*)calloc(broj_elemenata, sizeof(PODATAK_NAMIRNICA));

    if (dinamicko_polje == NULL)
    {
        perror("Greska alokacije");
        fclose(pokazivac);
        return;
    }

    fread(dinamicko_polje, sizeof(PODATAK_NAMIRNICA), broj_elemenata, pokazivac);
    fclose(pokazivac);

    qsort(dinamicko_polje, broj_elemenata, sizeof(PODATAK_NAMIRNICA), funkcija_za_qsort);

    pokazivac = fopen(BAZA_NAMIRNICE, "wb");

    if (pokazivac != NULL)
    {
        fwrite(dinamicko_polje, sizeof(PODATAK_NAMIRNICA), broj_elemenata, pokazivac);
        fclose(pokazivac);
        printf("Baza podataka uspjesno sortirana po energetskoj vrijednosti.\n");
    }

    free(dinamicko_polje);
    dinamicko_polje = NULL;
}

int rekurzivna_binarna_pretraga(PODATAK_NAMIRNICA* polje, int lijevo, int desno, int kljuc)
{
    int sredina;

    if (desno >= lijevo)
    {
        sredina = lijevo + (desno - lijevo) / 2;

        if (polje[sredina].identifikator == kljuc)
        {
            return sredina;
        }

        if (polje[sredina].identifikator > kljuc)
        {
            return rekurzivna_binarna_pretraga(polje, lijevo, sredina - 1, kljuc);
        }
        else
        {
            return rekurzivna_binarna_pretraga(polje, sredina + 1, desno, kljuc);
        }
    }

    return -1;
}

void pokreni_pretragu_baze(void)
{
    FILE* pokazivac;
    PODATAK_NAMIRNICA* polje;
    long velicina;
    int broj_podataka;
    int kljuc_pretrage;
    int rezultat_indeks;

    pokazivac = fopen(BAZA_NAMIRNICE, "rb");

    if (pokazivac == NULL)
    {
        perror("Greska baze");
        return;
    }

    fseek(pokazivac, 0, SEEK_END);
    velicina = ftell(pokazivac);
    broj_podataka = (int)(velicina / sizeof(PODATAK_NAMIRNICA));
    rewind(pokazivac);

    if (broj_podataka <= 0)
    {
        printf("Baza je prazna.\n");
        fclose(pokazivac);
        return;
    }

    polje = (PODATAK_NAMIRNICA*)malloc(broj_podataka * sizeof(PODATAK_NAMIRNICA));

    if (polje == NULL)
    {
        perror("Alokacija memorije nije uspjela");
        fclose(pokazivac);
        return;
    }

    fread(polje, sizeof(PODATAK_NAMIRNICA), broj_podataka, pokazivac);
    fclose(pokazivac);

    printf("Unesite ID za pretragu: ");
    kljuc_pretrage = provjera_unosa_int(1, 99999);

    rezultat_indeks = rekurzivna_binarna_pretraga(polje, 0, broj_podataka - 1, kljuc_pretrage);

    if (rezultat_indeks != -1)
    {
        printf("Uspjesna pretraga: Pronadjen naziv: %s\n", polje[rezultat_indeks].naziv);
    }
    else
    {
        printf("Na zalost, namirnica s ID %d nije pronadjena.\n", kljuc_pretrage);
    }

    free(polje);
    polje = NULL;
}

void napravi_sigurnosnu_kopiju(void)
{
    FILE* citanje;
    FILE* pisanje;
    int prenesen_bajt;

    citanje = fopen(BAZA_NAMIRNICE, "rb");

    if (citanje == NULL)
    {
        perror("Originalna datoteka nije dostupna");
        return;
    }

    pisanje = fopen(BACKUP_DATOTEKA, "wb");

    if (pisanje == NULL)
    {
        perror("Greska kod kreiranja backup datoteke");
        fclose(citanje);
        return;
    }

    while (1)
    {
        prenesen_bajt = fgetc(citanje);

        if (feof(citanje))
        {
            break;
        }

        if (ferror(citanje))
        {
            perror("Greska za vrijeme citanja");
            break;
        }

        fputc(prenesen_bajt, pisanje);
    }

    fclose(citanje);
    fclose(pisanje);

    printf("Kopiranje podataka u %s je zavrseno.\n", BACKUP_DATOTEKA);
}

