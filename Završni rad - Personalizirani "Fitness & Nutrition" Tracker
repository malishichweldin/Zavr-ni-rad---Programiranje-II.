void ispisi_ieee754_format(void)
{
    float upis_broja;
    unsigned int* pokazivac_memorije;
    int brojac_bita;
    unsigned int vrijednost_bita;

    printf("Unesite decimalni broj za provjeru standarda IEEE 754: ");
    upis_broja = provjera_unosa_float(-10000.0f, 10000.0f);

    pokazivac_memorije = (unsigned int*)&upis_broja;

    printf("Prikaz u memoriji (32-bit float): ");

    for (brojac_bita = 31; brojac_bita >= 0; brojac_bita = brojac_bita - 1)
    {
        vrijednost_bita = (*pokazivac_memorije >> brojac_bita) & 1;
        printf("%u", vrijednost_bita);

        if (brojac_bita == 31)
        {
            printf(" ");
        }
        else if (brojac_bita == 23)
        {
            printf(" ");
        }
    }
    printf("\n");
}
