CVOR_LISTE* dodaj_element_liste(CVOR_LISTE* pocetak)
{
    CVOR_LISTE* novi_element;
    CVOR_LISTE* privremeni_element;

    novi_element = (CVOR_LISTE*)malloc(sizeof(CVOR_LISTE));

    if (novi_element == NULL)
    {
        perror("Kriticna greska: Nema dostupne memorije");
        exit(EXIT_FAILURE);
    }

    printf("Unesite ID zapisa dnevnika: ");
    novi_element->unos.id_zapisa = provjera_unosa_int(1, 99999);

    printf("Unesite ID namirnice iz baze: ");
    novi_element->unos.referenca_namirnice = provjera_unosa_int(1, 99999);

    printf("Unesite kolicinu u gramima: ");
    novi_element->unos.kolicina_konzumirana = provjera_unosa_float(0.1f, 5000.0f);

    novi_element->sljedeci = NULL;

    if (pocetak == NULL)
    {
        return novi_element;
    }
    else
    {
        privremeni_element = pocetak;
        while (privremeni_element->sljedeci != NULL)
        {
            privremeni_element = privremeni_element->sljedeci;
        }
        privremeni_element->sljedeci = novi_element;
        return pocetak;
    }
}

